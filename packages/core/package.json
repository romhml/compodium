{
  "name": "@compodium/core",
  "type": "module",
  "version": "0.1.0-beta.10",
  "description": "A plug and play component playground for Vue and Nuxt.",
  "license": "MIT",
  "repository": {
    "url": "romhml/compodium",
    "directory": "packages/core"
  },
  "keywords": [
    "nuxt",
    "vue",
    "vite",
    "components",
    "documentation"
  ],
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "@compodium/dev": "./src/index.ts"
    },
    "./*": {
      "import": "./dist/*",
      "@compodium/dev": "./src/*"
    }
  },
  "scripts": {
    "prepack": "tsdown && pnpm --filter devtools generate",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "vite": ">=6",
    "vue": ">=3"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "dependencies": {
    "@compodium/examples": "workspace:^",
    "@compodium/meta": "workspace:^",
    "@vueuse/core": "^13.3.0",
    "chokidar": "^4.0.3",
    "hookable": "^5.5.3",
    "mlly": "^1.7.4",
    "pathe": "^2.0.3",
    "scule": "^1.3.0",
    "sirv": "^3.0.1",
    "tinyglobby": "^0.2.14",
    "ufo": "^1.6.1",
    "unplugin": "^2.3.5",
    "unplugin-ast": "^0.15.0",
    "zod": "^3.25.49"
  }
}
