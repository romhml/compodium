{
  "name": "@compodium/core",
  "type": "module",
  "version": "0.1.0-beta.13",
  "description": "A plug and play component playground for Vue and Nuxt.",
  "license": "MIT",
  "repository": {
    "url": "romhml/compodium",
    "directory": "packages/core"
  },
  "keywords": [
    "nuxt",
    "vue",
    "vite",
    "components",
    "documentation"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.mjs"
      },
      "./*": "./dist/*"
    }
  },
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "unbuild && pnpm --filter devtools generate",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "typescript": ">=5.8",
    "vite": ">=7",
    "vue": ">=3"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "dependencies": {
    "@compodium/examples": "workspace:^",
    "@vue/compiler-sfc": "^3.5.40",
    "@vue/language-core": "^3.3.8",
    "@vueuse/core": "^14.3.0",
    "chokidar": "^5.0.0",
    "defu": "^6.1.7",
    "hookable": "^6.1.1",
    "mlly": "^1.8.2",
    "oxc-parser": "^0.141.0",
    "pathe": "^2.0.3",
    "scule": "^1.3.0",
    "sirv": "^3.0.2",
    "tinyglobby": "^0.2.17",
    "ufo": "^1.6.4",
    "unplugin": "^3.3.0",
    "unplugin-ast": "^0.17.2",
    "vue-component-meta": "3.3.8",
    "zod": "^4.4.3"
  }
}
