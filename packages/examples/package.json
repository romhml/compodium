{
  "name": "@compodium/examples",
  "version": "0.1.0-beta.10",
  "description": "Third party library examples for Compodium",
  "type": "module",
  "license": "MIT",
  "repository": {
    "url": "romhml/compodium",
    "directory": "packages/examples"
  },
  "files": ["dist"],
  "exports": {
    ".": {
      "@compodium/dev": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./*": {
      "@compodium/dev": "./src/*",
      "import": "./dist/*"
    }
  },
  "scripts": {
    "prepack": "tailwindcss -i src/assets/ui/base.css -o src/assets/ui/index.css && tsdown"
  },
  "dependencies": {
    "pathe": "^2.0.3",
    "scule": "^1.3.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.14",
    "tailwindcss": "^4.0.14"
  }
}
