{
  "name": "@compodium/vue",
  "type": "module",
  "version": "0.1.0-beta.12",
  "description": "A plug and play component playground for Vue and Nuxt.",
  "license": "MIT",
  "repository": {
    "url": "romhml/compodium",
    "directory": "packages/vue"
  },
  "keywords": [
    "vue",
    "components",
    "documentation"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.mjs"
      },
      "./*": "./dist/*"
    }
  },
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "unbuild",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "vite": ">=7"
  },
  "dependencies": {
    "@compodium/core": "workspace:^",
    "@compodium/examples": "workspace:^",
    "@vue/devtools-kit": "^8.1.5",
    "consola": "^3.4.2",
    "defu": "^6.1.7",
    "mlly": "^1.8.2",
    "pathe": "^2.0.3",
    "ufo": "^1.6.4",
    "unplugin": "^3.3.0"
  }
}
