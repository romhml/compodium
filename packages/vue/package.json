{
  "name": "@compodium/vue",
  "type": "module",
  "version": "0.1.0-beta.10",
  "description": "A plug and play component playground for Vue and Nuxt.",
  "license": "MIT",
  "repository": {
    "url": "romhml/compodium",
    "directory": "packages/vue"
  },
  "keywords": [
    "vue",
    "components",
    "documentation"
  ],
  "files": ["dist"],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./*": {
      "import": "./dist/*"
    }
  },
  "scripts": {
    "prepack": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "vite": ">=6"
  },
  "dependencies": {
    "@compodium/core": "workspace:^",
    "@compodium/examples": "workspace:^",
    "@vue/devtools-kit": "^7.7.6",
    "consola": "^3.4.2",
    "defu": "^6.1.4",
    "mlly": "^1.7.4",
    "pathe": "^2.0.3",
    "unplugin": "^2.3.5"
  }
}
